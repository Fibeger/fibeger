# Database
DATABASE_URL=postgres://admin:password@localhost:5432/fibeger

# Auth
JWT_SECRET=your-secret-key-here

# Server
PORT=8080
GIN_MODE=debug
AUTO_MIGRATE=true

# S3 Storage (optional, falls back to local)
S3_BUCKET=fibeger
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=admin
S3_SECRET_ACCESS_KEY=password
S3_USE_TLS=false
S3_PUBLIC_URL=

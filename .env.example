# Fibeger Environment Configuration
# Copy this file to .env on your production server

# ==============================================
# Admin Credentials
# ==============================================
# Used for PostgreSQL, MinIO, and pgAdmin
ADMIN_USER=admin
ADMIN_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD

# ==============================================
# JWT Secret
# ==============================================
# Used by Go backend for token signing
# Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_STRING

# ==============================================
# URLs
# ==============================================
API_URL=http://backend:8080
WS_URL=ws://backend:8080/ws
S3_PUBLIC_URL=https://your-domain.com/minio

# ==============================================
# Container Images
# ==============================================
BACKEND_IMAGE_REF=ghcr.io/yourusername/fibeger-backend:latest
WEB_IMAGE_REF=ghcr.io/yourusername/fibeger-web:latest
